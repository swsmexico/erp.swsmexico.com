APP_NAME="SWS Mexico ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://erp.swsmexico.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sws_erp
DB_USERNAME=
DB_PASSWORD=

# ── Cache y colas ─────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Email SMTP Ionos ──────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.ionos.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@swsmexico.com"
MAIL_FROM_NAME="SWS Mexico"

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── SAT / phpcfdi ─────────────────────────────────────────────────────────────
SAT_RFC_EMPRESA=
SAT_CIEC=

# ── Linear API ────────────────────────────────────────────────────────────────
LINEAR_API_TOKEN=

# ── WhatsApp microservicio ────────────────────────────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:3001

# ── Horizon ──────────────────────────────────────────────────────────────────
HORIZON_BASIC_AUTH_USERNAME=admin
HORIZON_BASIC_AUTH_PASSWORD=
